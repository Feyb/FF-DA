#!/usr/bin/env sh

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
	# Load nvm in non-interactive git hook shells and switch to .nvmrc version.
	. "$NVM_DIR/nvm.sh"
	nvm use --silent >/dev/null 2>&1 || true
fi

node_major="$(node -p "process.versions.node.split('.')[0]" 2>/dev/null)"
if [ -z "$node_major" ] || [ "$node_major" -lt 20 ]; then
	echo "[husky] Node.js 20+ is required for pre-commit checks (current: $(node -v 2>/dev/null || echo 'not found'))."
	echo "[husky] Run: nvm use 20 (or upgrade Node), then run pnpm install and retry commit."
	exit 1
fi

corepack pnpm exec lint-staged
