{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "off"
  },
  "ignorePatterns": ["dist/**", ".angular/**", "coverage/**"],
  "overrides": [
    {
      "files": ["**/*.spec.ts", "**/*.test.ts"],
      "env": {
        "jasmine": true
      }
    }
  ]
}
