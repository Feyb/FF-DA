{
  "name": "@ff/draft-assistant-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "ktc:sync": "node ./scripts/fetch-ktc-players.mjs",
    "flock:sync": "node ./scripts/fetch-flock-players.mjs",
    "fp:sync": "node ./scripts/fetch-fantasypros-adp.mjs",
    "fc:sync": "node ./scripts/fetch-fantasycalc.mjs",
    "ffc:sync": "node ./scripts/fetch-ffc-adp.mjs",
    "sleeper:stats:sync": "node ./scripts/fetch-sleeper-stats.mjs",
    "nflverse:player-stats:sync": "node ./scripts/fetch-nflverse-player-stats.mjs",
    "nflverse:pfr:sync": "node ./scripts/fetch-nflverse-pfr-advstats.mjs",
    "nflverse:ngs:sync": "node ./scripts/fetch-nflverse-ngs.mjs",
    "nflverse:ff-opp:sync": "node ./scripts/fetch-nflverse-ff-opportunity.mjs",
    "nflverse:draft-picks:sync": "node ./scripts/fetch-nflverse-draft-picks.mjs",
    "nflverse:combine:sync": "node ./scripts/fetch-nflverse-combine.mjs",
    "nflverse:rosters:sync": "node ./scripts/fetch-nflverse-rosters.mjs",
    "espn:rosters:sync": "node ./scripts/fetch-espn-rosters.mjs",
    "nflverse:sync": "pnpm run nflverse:player-stats:sync && pnpm run nflverse:pfr:sync && pnpm run nflverse:ngs:sync && pnpm run nflverse:ff-opp:sync && pnpm run nflverse:draft-picks:sync && pnpm run nflverse:combine:sync && pnpm run nflverse:rosters:sync && pnpm run espn:rosters:sync",
    "cfbd:sync": "node ./scripts/fetch-cfbd-rookies.mjs",
    "rankings:sync": "pnpm run ktc:sync && pnpm run flock:sync && pnpm run fp:sync && pnpm run fc:sync && pnpm run ffc:sync && pnpm run sleeper:stats:sync && pnpm run nflverse:sync && pnpm run cfbd:sync",
    "start": "ng serve",
    "start-sync": "pnpm run rankings:sync && ng serve",
    "build": "pnpm run rankings:sync && ng build",
    "build:ci": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:ng": "ng lint",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/material": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@ngrx/operators": "^20.0.0",
    "@ngrx/signals": "^20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.15.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.8.0"
  }
}
